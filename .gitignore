# User Identity & Tokens
.user-identity
.gh-token

# Environment
.env
.env.local
.env.*.local

# Project-Specific (각 프로젝트 독립, 동기화 안 함)
flows/                                   # 프로젝트별 서비스 플로우 구현
projects/                                # 프로젝트별 소스 코드
.claude/state/logs/                      # 세션 로그
.claude/state/pids/                      # 프로세스 ID
.claude/state/*/                         # 프로젝트별 state

# Template State (공유 안 함, 로컬만)
.claude/state/_schema_version.txt
.claude/state/_active_flow.txt
state/
pending-issues/

# Migrations (마이그레이션 이력, 로컬만)
.claude/migrations/v*-to-v*.sh.bak

# Dependencies
node_modules/
.pnpm-store/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Build outputs
.next/
out/
storybook-static/

# Testing & Browser
.playwright/
.playwright-mcp/
.firecrawl/

# Test Artifacts & Reports (동적으로 생성되는 파일들)
.claude/tests/.temp/                # 테스트 중 임시 파일
.claude/tests/coverage/             # 테스트 커버리지 리포트
.claude/tests/*.log                 # 테스트 로그
.claude/tests/**/.temp/             # 하위 디렉토리 임시 파일

# Reports (프로젝트 완료도 요약 등)
.claude/state/reports/              # 완료 보고서, 요약 문서 등

# Tools Cache
.qodo/

# Misc
.cache/

docs/